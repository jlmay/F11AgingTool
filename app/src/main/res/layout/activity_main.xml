<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1565C0"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="F11-N 底座老化测试工具"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● 空闲"
            android:textColor="#A5D6A7"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 主内容滚动区 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- ===== 老化模式 ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="老化模式"
                android:textColor="#1565C0"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <RadioGroup
                android:id="@+id/rgMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:padding="8dp">
                <RadioButton
                    android:id="@+id/rbModeNormal"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="模式1：不断电循环（断电自动恢复）"
                    android:textSize="14sp"
                    android:checked="true" />
                <RadioButton
                    android:id="@+id/rbModeReboot"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="模式2：每轮测试后重启"
                    android:textSize="14sp" />
            </RadioGroup>

            <!-- ===== 参数设置 ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="参数设置"
                android:textColor="#1565C0"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingTop="10dp"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="测试总次数："
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/etTotalCount"
                        android:layout_width="100dp"
                        android:layout_height="40dp"
                        android:text="100"
                        android:inputType="number"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@android:drawable/edit_text" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" 次"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="启动延时："
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/etStartDelay"
                        android:layout_width="100dp"
                        android:layout_height="40dp"
                        android:text="0"
                        android:inputType="number"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@android:drawable/edit_text" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" 毫秒"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutPingConfig"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="PING 地址："
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/etPingHost"
                        android:layout_width="160dp"
                        android:layout_height="40dp"
                        android:text="www.baidu.com"
                        android:inputType="text"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:background="@android:drawable/edit_text" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutPingCount"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="PING 次数："
                        android:textSize="14sp" />
                    <EditText
                        android:id="@+id/etPingCount"
                        android:layout_width="100dp"
                        android:layout_height="40dp"
                        android:text="10"
                        android:inputType="number"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@android:drawable/edit_text" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" 次"
                        android:textSize="14sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- ===== 测试项目 ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="测试项目（可多选）"
                android:textColor="#1565C0"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingTop="10dp"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="8dp">

                <CheckBox
                    android:id="@+id/cbIdCard"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="① 身份证读取（读出姓名+号码）"
                    android:textSize="14sp"
                    android:checked="true" />
                <CheckBox
                    android:id="@+id/cbContactlessCard"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="② 非接触CPU卡（寻卡+复位+取随机数）"
                    android:textSize="14sp"
                    android:checked="true" />
                <CheckBox
                    android:id="@+id/cbContactCard"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="③ 接触CPU卡（复位+取随机数）"
                    android:textSize="14sp"
                    android:checked="false" />
                <CheckBox
                    android:id="@+id/cbEthernet"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="④ 以太网（PING 测试）"
                    android:textSize="14sp"
                    android:checked="true" />
                <CheckBox
                    android:id="@+id/cbBarcode"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="⑤ 扫码测试（扫码比对）"
                    android:textSize="14sp"
                    android:checked="false" />

            </LinearLayout>

            <!-- ===== 扫码样本区 ===== -->
            <LinearLayout
                android:id="@+id/layoutBarcodeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFF8E1"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="样本码："
                    android:textSize="14sp"
                    android:textColor="#E65100" />
                <EditText
                    android:id="@+id/etBarcodeRef"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:hint="请先扫描待测二维码..."
                    android:textSize="13sp"
                    android:background="@android:drawable/edit_text"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- ===== 统计数据 ===== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="测试统计"
                android:textColor="#1565C0"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingTop="10dp"
                android:paddingBottom="4dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:padding="8dp"
                android:columnCount="4"
                android:rowCount="2">

                <TextView android:text="已测：" android:textSize="13sp" android:textColor="#555" />
                <TextView
                    android:id="@+id/tvCurrentCount"
                    android:text="0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:minWidth="60dp" />
                <TextView android:text="总计：" android:textSize="13sp" android:textColor="#555" />
                <TextView
                    android:id="@+id/tvTotalCount"
                    android:text="100"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333"
                    android:minWidth="60dp" />
                <TextView android:text="成功：" android:textSize="13sp" android:textColor="#555" android:layout_marginTop="4dp"/>
                <TextView
                    android:id="@+id/tvSuccessCount"
                    android:text="0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#388E3C"
                    android:minWidth="60dp"
                    android:layout_marginTop="4dp"/>
                <TextView android:text="失败：" android:textSize="13sp" android:textColor="#555" android:layout_marginTop="4dp"/>
                <TextView
                    android:id="@+id/tvFailCount"
                    android:text="0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#C62828"
                    android:minWidth="60dp"
                    android:layout_marginTop="4dp"/>
            </GridLayout>

            <!-- ===== 控制按钮 ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="10dp">
                <Button
                    android:id="@+id/btnStart"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="开始测试"
                    android:textSize="16sp"
                    android:backgroundTint="#1565C0"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="6dp" />
                <Button
                    android:id="@+id/btnStop"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="停止测试"
                    android:textSize="16sp"
                    android:backgroundTint="#C62828"
                    android:textColor="#FFFFFF"
                    android:enabled="false"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnViewLog"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="查看历史日志"
                android:textSize="14sp"
                android:backgroundTint="#546E7A"
                android:textColor="#FFFFFF"
                android:layout_marginTop="6dp" />

        </LinearLayout>
    </ScrollView>

    <!-- ===== 网络信息固定显示区（独立于日志） ===== -->
    <LinearLayout
        android:id="@+id/layoutNetworkInfo"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:background="#FFF3E0"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IP: "
            android:textSize="13sp"
            android:textColor="#F57C00" />

        <TextView
            android:id="@+id/tvIpAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textSize="13sp"
            android:textColor="#BF360C" />
    </LinearLayout>

    <!-- ===== 实时日志区 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:orientation="vertical"
        android:background="#1A237E">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="实时日志"
                android:textColor="#90CAF9"
                android:textSize="12sp"
                android:textStyle="bold" />
            <Button
                android:id="@+id/btnClearLog"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="清除"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#37474F"
                android:paddingHorizontal="8dp" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/scrollLog"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp">
            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="等待开始测试...\n"
                android:textColor="#E3F2FD"
                android:textSize="12sp"
                android:fontFamily="monospace" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>
